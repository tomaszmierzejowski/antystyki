{
  "Urls": "http://localhost:5000",
  "Authentication": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "service": "antystics-api"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": {
            "type": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
          }
        }
      }
    ]
  },
  "Sentry": {
    "Dsn": "",
    "Enabled": false,
    "Environment": "Development",
    "Release": "antystics@dev",
    "SendDefaultPii": false,
    "TracesSampleRate": 0.0
  },
  "VisitorMetrics": {
    "RetentionDays": 30,
    "FlushIntervalMinutes": 1,
    "TrackBots": true
  },
  "ContentGeneration": {
    "GeminiApiKey": "",
    "GeminiModel": "gemini-2.5-flash",
    "EnforceTrustedSources": true,
    "MinimumSourceReliability": 4,
    "RequireSourceUrlHttp200": true,
    "MinimumValidationConfidence": 0.6,
    "SourceHealthMaxAttempts": 3,
    "SourceFetchMaxAttempts": 3,
    "SourceUrlCheckMaxAttempts": 2,
    "RetryBaseDelaySeconds": 2,
    "RunMaxAttempts": 2,
    "RunAtStartup": false,
    "StartupDelaySeconds": 10
  }
}
